# Sciread Environment Configuration Example
# Copy this file to .env and fill in your API keys

# --- LLM Providers ---
# DeepSeek (Standard name)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Volcengine / Ark (Standard names)
VOLCES_API=your_volcengine_api_key_here
ARK_API_KEY=your_ark_api_key_here

# --- PDF to Markdown Conversion ---
# Mineru (Required for PDF processing via Mineru API)
MINERU_TOKEN=your_mineru_token_here

# --- Project Settings (Optional) ---
# These can also be configured in sciread.toml
# SCIREAD_DEFAULT__PROVIDER=deepseek
# SCIREAD_DEFAULT__MODEL=deepseek-chat
# SCIREAD_LOG_LEVEL=INFO
